<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "../testng-1.0.dtd">

<suite name="Suite" preserve-order="true">

	<test thread-count="5" name="Test">
		<parameter name="configFile" value="oqndc.properties" />
		<classes>
			<class name="testCasesForOQProjects.NDC_TC">
				<methods>
					<include name="url" />
					<include name="userLoginBeforeCreate" />
					<include name="moduleClick" />
					<include name="Click_Actions" />
					
					<!-- Inactive Flow-->
					
					<!-- Iteration 1 -->
					<include name="Click_Inactive_1" />
					<include name="ndc_Inactive_Review_Reject" />
					
					<!-- Iteration 2 -->
					<include name="Click_Inactive_2" />
					<include name="ndc_Inactive_Review_1" />
					<include name="ndc_Inactive_Approve_Reject" />
					
					<!-- Iteration 3 -->
					<include name="Click_Inactive_3" />
					<include name="ndc_Inactive_Review_2" />
					<include name="ndc_Inactive_Approve" />
					
					<!-- Active Flow-->
					
					<!-- Iteration 1 -->
					<include name="Click_Active_1" />
					<include name="ndc_Active_Review_Reject" />
					
					<!-- Iteration 2 -->
					<include name="Click_Active_2" />
					<include name="ndc_Active_Review_1" />
					<include name="ndc_Active_Approve_Reject" />
					
					<!-- Iteration 3 -->
					<include name="Click_Active_3" />
					<include name="ndc_Active_Review_2" />
					<include name="ndc_Active_Approve" />
					
					<include name="Logout" />
					<include name="Database_Backup" />
				</methods>
			</class>
		</classes>
	</test>

</suite>
